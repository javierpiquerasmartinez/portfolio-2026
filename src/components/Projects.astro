---
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';
import type { Translations } from '../i18n/utils';
import projects from '../data/projects.json';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="projects" id="projects" aria-label={t['projects.label']}>
  <div class="projects__inner">
    <SectionHeading label={t['projects.label']} number={t['projects.number']} />
    <div class="projects__grid">
      {projects.map((project) => (
        <ProjectCard project={project} t={t} />
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 6vw, 8rem);
    max-width: 72rem;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .projects.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  @media (max-width: 640px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .projects {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('.projects');
  if (section) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      section.classList.add('is-visible');
    } else {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');
            observer.unobserve(section);
          }
        },
        { threshold: 0.1 }
      );
      observer.observe(section);
    }
  }
</script>
