---
import type { Translations } from '../i18n/utils';

interface ExperienceItem {
  title: string;
  company: string;
  startDate: string;
  endDate: string | null;
  current: boolean;
  bullets: string[];
  techStack: string[];
}

interface Props {
  entry: ExperienceItem;
  index: number;
  duration: string;
  t: Translations;
}

const { entry, index, duration, t } = Astro.props;
---

<article
  class="experience__entry"
  data-index={index}
  aria-label={`${entry.title} at ${entry.company}`}
>
  <div class={`experience__dot${entry.current ? ' experience__dot--current' : ''}`} aria-hidden="true"></div>

  <div class="experience__body">
    <h3 class="experience__title">{entry.title}</h3>
    <p class="experience__company">{entry.company}</p>

    <p class="experience__dates">
      {entry.startDate}
      <span aria-hidden="true"> — </span>
      {entry.current ? t['experience.present'] : entry.endDate}
      <span class="experience__duration">
        · {duration}
      </span>
    </p>

    <ul class="experience__bullets">
      {entry.bullets.map((bullet) => (
        <li class="experience__bullet">{bullet}</li>
      ))}
    </ul>

    <ul class="experience__stack" aria-label="Technologies">
      {entry.techStack.map((tech) => (
        <li class="experience__badge">{tech}</li>
      ))}
    </ul>
  </div>
</article>

<style>
  .experience__entry {
    position: relative;
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    padding-bottom: 3rem;
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 0.5s var(--ease-smooth),
      transform 0.5s var(--ease-smooth);
  }

  .experience__entry.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .experience__entry.is-dimmed {
    opacity: 0.35;
    transition: opacity 0.25s ease;
  }

  .experience__dot {
    position: relative;
    top: 0.35rem;
    width: 0.875rem;
    height: 0.875rem;
    border-radius: 50%;
    border: 1px solid var(--accent-dim);
    background-color: transparent;
    justify-self: center;
    flex-shrink: 0;
  }

  .experience__dot--current {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .experience__title {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .experience__company {
    font-size: clamp(0.85rem, 1.5vw, 0.95rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .experience__dates {
    font-size: clamp(0.7rem, 1.2vw, 0.8rem);
    font-family: 'Courier New', monospace;
    color: var(--text-faded);
    margin-bottom: 1.25rem;
    font-variant-numeric: tabular-nums;
  }

  .experience__duration {
    color: rgba(255, 255, 255, 0.3);
  }

  .experience__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .experience__bullet {
    font-size: clamp(0.8rem, 1.4vw, 0.875rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    padding-left: 1.25em;
    position: relative;
  }

  .experience__bullet::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent-dim);
  }

  .experience__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .experience__badge {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 0.2em 0.55em;
  }

  @media (prefers-reduced-motion: reduce) {
    .experience__entry {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .experience__entry.is-dimmed {
      opacity: 0.35;
      transition: none;
    }
  }
</style>
