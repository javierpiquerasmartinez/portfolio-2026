---
import SectionHeading from './SectionHeading.astro';
import type { Translations } from '../i18n/utils';
import cv from '../data/cv.json';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { email, linkedin, github } = cv.personal;
---

<section id="contact" aria-label={t['contact.label']}>
  <div class="contact__inner">
    <SectionHeading number={t['contact.number']} label={t['contact.label']} />
    <p class="contact__subtitle">{t['contact.subtitle']}</p>

    <div class="contact__body">
      <!-- Left column: CTA + links -->
      <div class="contact__info">
        <p class="contact__cta">{t['contact.cta.headline']}</p>
        <ul class="contact__links">
          <li>
            <a href={`mailto:${email}`} class="contact__link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m2 7 10 7 10-7"/>
              </svg>
              {t['contact.links.email']}
            </a>
          </li>
          <li>
            <a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact__link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              {t['contact.links.linkedin']}
            </a>
          </li>
          <li>
            <a href={github} target="_blank" rel="noopener noreferrer" class="contact__link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              {t['contact.links.github']}
            </a>
          </li>
        </ul>
      </div>

      <!-- Right column: form -->
      <div class="contact__form-wrap">
        <form
          id="contact-form"
          novalidate
          data-msg-required={t['contact.error.required']}
          data-msg-email={t['contact.error.email']}
          data-msg-sending={t['contact.form.sending']}
          data-msg-submit={t['contact.form.submit']}
          data-msg-server={t['contact.error.server']}
        >
          <div class="field">
            <label for="contact-name">{t['contact.form.name']}</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              placeholder={t['contact.form.name.ph']}
              autocomplete="off"
            />
            <span class="field__error" aria-live="polite"></span>
          </div>

          <div class="field">
            <label for="contact-email">{t['contact.form.email']}</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              placeholder={t['contact.form.email.ph']}
              autocomplete="off"
            />
            <span class="field__error" aria-live="polite"></span>
          </div>

          <div class="field">
            <label for="contact-message">{t['contact.form.message']}</label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              placeholder={t['contact.form.message.ph']}
            ></textarea>
            <span class="field__error" aria-live="polite"></span>
          </div>

          <button type="submit" class="contact__submit">
            {t['contact.form.submit']}
          </button>
          <span class="form__error-server" aria-live="polite"></span>
        </form>

        <!-- Success state -->
        <div class="contact__success" aria-hidden="true" id="contact-success">
          <svg class="contact__success-icon" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="2"/>
            <path d="M20 32l9 9 15-16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h3 class="contact__success-title">{t['contact.success.title']}</h3>
          <p class="contact__success-body">{t['contact.success.body']}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('contact-success') as HTMLElement | null;

  if (form && successEl) {
    const MSG_REQUIRED = form.dataset.msgRequired ?? 'This field is required.';
    const MSG_EMAIL    = form.dataset.msgEmail    ?? 'Enter a valid email address.';
    const MSG_SENDING  = form.dataset.msgSending  ?? 'Sending...';
    const MSG_SUBMIT   = form.dataset.msgSubmit   ?? 'Send message';
    const MSG_SERVER   = form.dataset.msgServer   ?? 'Something went wrong. Please try again.';
    const serverError  = form.querySelector('.form__error-server') as HTMLElement | null;
    const EMAIL_RE     = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function getField(name: string) {
      return form!.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLTextAreaElement;
    }

    function getError(field: HTMLInputElement | HTMLTextAreaElement) {
      return field.closest('.field')?.querySelector('.field__error') as HTMLElement;
    }

    function setError(field: HTMLInputElement | HTMLTextAreaElement, msg: string) {
      field.classList.add('error');
      const err = getError(field);
      if (err) err.textContent = msg;
    }

    function clearError(field: HTMLInputElement | HTMLTextAreaElement) {
      field.classList.remove('error');
      const err = getError(field);
      if (err) err.textContent = '';
    }

    function shake(field: HTMLInputElement | HTMLTextAreaElement) {
      const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (mq.matches) return;
      field.classList.remove('shake');
      // Force reflow
      void field.offsetWidth;
      field.classList.add('shake');
      field.addEventListener('animationend', () => field.classList.remove('shake'), { once: true });
    }

    // Live clear on input
    ['name', 'email', 'message'].forEach((name) => {
      const field = getField(name);
      if (field) {
        field.addEventListener('input', () => clearError(field));
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nameField    = getField('name');
      const emailField   = getField('email');
      const messageField = getField('message');

      let valid = true;

      if (!nameField.value.trim()) {
        setError(nameField, MSG_REQUIRED);
        shake(nameField);
        valid = false;
      }

      if (!emailField.value.trim()) {
        setError(emailField, MSG_REQUIRED);
        shake(emailField);
        valid = false;
      } else if (!EMAIL_RE.test(emailField.value.trim())) {
        setError(emailField, MSG_EMAIL);
        shake(emailField);
        valid = false;
      }

      if (!messageField.value.trim()) {
        setError(messageField, MSG_REQUIRED);
        shake(messageField);
        valid = false;
      }

      if (!valid) return;

      const btn = form!.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = MSG_SENDING;
      if (serverError) serverError.textContent = '';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: nameField.value.trim(),
            email: emailField.value.trim(),
            message: messageField.value.trim(),
          }),
        });

        const json = await res.json();
        if (!res.ok || !json.ok) throw new Error(json.error ?? 'unknown');

        form!.style.opacity = '0';
        form!.style.transform = 'translateY(-0.5rem)';
        setTimeout(() => {
          form!.style.display = 'none';
          successEl!.removeAttribute('aria-hidden');
          successEl!.classList.add('visible');
        }, 300);

      } catch {
        btn.disabled = false;
        btn.textContent = MSG_SUBMIT;
        if (serverError) serverError.textContent = MSG_SERVER;
      }
    });
  }

  // Entrance animation via IntersectionObserver
  const section = document.getElementById('contact');
  if (section) {
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!mq.matches) {
      section.style.opacity = '0';
      section.style.transform = 'translateY(0.75rem)';
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            section.style.transition = 'opacity 0.6s var(--ease-smooth), transform 0.6s var(--ease-smooth)';
            section.style.opacity = '1';
            section.style.transform = 'translateY(0)';
            observer.disconnect();
          }
        },
        { threshold: 0.1 }
      );
      observer.observe(section);
    }
  }
</script>

<style>
  #contact {
    padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 6vw, 8rem);
    max-width: 72rem;
    margin: 0 auto;
  }

  .contact__subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: var(--text-muted);
    margin-top: -2rem;
    margin-bottom: 3rem;
    max-width: 48ch;
  }

  /* Two-column grid */
  .contact__body {
    display: grid;
    grid-template-columns: 1fr 1.85fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  /* Left column */
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.25rem;
  }

  .contact__cta {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .contact__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .contact__link:hover {
    color: var(--color-accent);
  }

  .contact__link svg {
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  /* Right column */
  .contact__form-wrap {
    position: relative;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Fields */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .field input,
  .field textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    resize: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
    background: rgba(232, 255, 71, 0.03);
    box-shadow: 0 0 0 3px rgba(232, 255, 71, 0.12);
  }

  .field input.error,
  .field textarea.error {
    border-color: #ff5555;
    background: rgba(255, 85, 85, 0.04);
    box-shadow: 0 0 0 3px rgba(255, 85, 85, 0.10);
  }

  .field__error {
    font-size: 0.75rem;
    color: #ff5555;
    min-height: 1rem;
    line-height: 1;
  }

  /* Shake animation */
  @keyframes shake {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(-4px); }
    40%  { transform: translateX(4px); }
    60%  { transform: translateX(-4px); }
    80%  { transform: translateX(2px); }
    100% { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .field input.shake,
    .field textarea.shake {
      animation: shake 0.3s ease;
    }
  }

  .form__error-server {
    font-size: 0.8rem;
    color: #ff5555;
    min-height: 1rem;
  }

  /* Submit button */
  .contact__submit {
    align-self: flex-start;
    background: var(--color-accent);
    color: #0a0a0a;
    border: none;
    border-radius: 6px;
    padding: 0.75rem 1.75rem;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .contact__submit:hover:not(:disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .contact__submit:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  /* Success state */
  .contact__success {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    padding: 3rem 1rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .contact__success.visible {
    display: flex;
    opacity: 1;
  }

  .contact__success-icon {
    width: 3.5rem;
    height: 3.5rem;
    color: var(--color-accent);
  }

  .contact__success-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .contact__success-body {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact__body {
      grid-template-columns: 1fr;
    }

    .contact__cta {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 640px) {
    .contact__submit {
      align-self: stretch;
    }
  }
</style>
