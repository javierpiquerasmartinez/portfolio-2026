---
import StackBadge from './StackBadge.astro';

interface Skill {
  name: string;
  slug: string | null;
  note: string | null;
}

interface Props {
  label: string;
  skills: Skill[];
}

const { label, skills } = Astro.props;
---

<div class="stack-category">
  <h3 class="stack-category__label">{label}</h3>
  <ul class="stack-category__badges">
    {skills.map((skill) => (
      <StackBadge name={skill.name} slug={skill.slug} note={skill.note} />
    ))}
  </ul>
</div>

<style>
  .stack-category {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stack-category__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .stack-category__badges {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
</style>
