---
import type { Translations } from '../../i18n/utils';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<ul class="navbar__links" role="list" id="nav-menu">
  <li><a href="#about"      class="navbar__link" data-section="about">{t['nav.about']}</a></li>
  <li><a href="#experience" class="navbar__link" data-section="experience">{t['nav.experience']}</a></li>
  <li><a href="#stack"      class="navbar__link" data-section="stack">{t['nav.stack']}</a></li>
  <li><a href="#contact"    class="navbar__link" data-section="contact">{t['nav.contact']}</a></li>
</ul>

<style>
  .navbar__links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 0.25rem;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }

  .navbar__link:hover,
  .navbar__link:focus-visible {
    color: #ffffff;
  }

  .navbar__link.active {
    color: var(--color-accent);
  }

  .navbar__link.active::after {
    transform: scaleX(1);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .navbar__links {
      position: fixed;
      inset: 3.5rem 0 0 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      background-color: rgba(10, 10, 10, 0.97);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transform: translateX(100%);
      transition: transform 0.3s var(--ease-smooth);
      pointer-events: none;
    }

    .navbar__links.nav-open {
      transform: translateX(0);
      pointer-events: auto;
    }

    .navbar__link {
      font-size: 1.05rem;
      letter-spacing: 0.15em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar__link,
    .navbar__link::after,
    .navbar__links {
      transition: none;
    }
  }
</style>
