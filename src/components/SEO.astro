---
import cv from '../data/cv.json';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es';
  canonicalUrl: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang,
  canonicalUrl,
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = 'https://javipiqueras.dev';
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
const ogLocaleAlternate = lang === 'es' ? 'en_US' : 'es_ES';

// Flatten all skills into a knowsAbout array
const allSkills = [
  ...cv.skills.frontend,
  ...cv.skills.backend,
  ...cv.skills.databases,
  ...cv.skills.devops,
  ...cv.skills.other,
].map((s) => s.name);

// Current employer
const currentJob = cv.experience.find((e) => e.current);

const graphSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: cv.personal.name,
      jobTitle: cv.personal.title,
      description: cv.about,
      image: ogImageAbsolute,
      url: siteUrl,
      email: cv.personal.email,
      knowsAbout: allSkills,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Valencia',
        addressCountry: 'ES',
      },
      ...(currentJob && {
        worksFor: {
          '@type': 'Organization',
          name: currentJob.company,
        },
      }),
      sameAs: [
        cv.personal.linkedin,
        cv.personal.github,
      ],
    },
    {
      '@type': 'WebSite',
      url: siteUrl,
      name: title,
      description: description,
      inLanguage: ['en', 'es'],
      author: {
        '@type': 'Person',
        name: cv.personal.name,
      },
    },
  ],
};
---

<!-- Primary Meta Tags -->
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<meta name="author" content={cv.personal.name} />
<meta name="theme-color" content="#0a0a0a" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${cv.personal.name} — ${cv.personal.title}`} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:creator" content="@javierpiquerasmartinez" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
<meta name="twitter:image:alt" content={`${cv.personal.name} — ${cv.personal.title}`} />

<!-- Canonical & Hreflang -->
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="en" href={`${siteUrl}/`} />
<link rel="alternate" hreflang="es" href={`${siteUrl}/es/`} />
<link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

<!-- Structured Data (JSON-LD) -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(graphSchema)} />
