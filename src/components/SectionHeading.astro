---
interface Props {
  label: string;
  number?: string;
}

const { label, number } = Astro.props;
---

<div class="section-heading">
  {number && <span class="section-heading__number" aria-hidden="true">{number}</span>}
  <h2 class="section-heading__title">{label}</h2>
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 3rem;
  }

  .section-heading__number {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .section-heading__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1;
  }
</style>
