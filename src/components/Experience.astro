---
import type { Translations, Locale } from '../i18n/utils';
import SectionHeading from './SectionHeading.astro';
import ExperienceEntry from './ExperienceEntry.astro';
import cvData from '../data/cv.json';

interface Props {
  t: Translations;
  lang: Locale;
}

const { t, lang } = Astro.props;

const MONTHS: Record<string, number> = {
  January: 0, February: 1, March: 2, April: 3,
  May: 4, June: 5, July: 6, August: 7,
  September: 8, October: 9, November: 10, December: 11
};

function parseMonthYear(s: string): Date {
  const [month, year] = s.split(' ');
  return new Date(Number(year), MONTHS[month], 1);
}

function calcDuration(startStr: string, endStr: string | null): string {
  const start = parseMonthYear(startStr);
  const end = endStr ? parseMonthYear(endStr) : new Date();
  let years = end.getFullYear() - start.getFullYear();
  let months = end.getMonth() - start.getMonth();
  if (months < 0) { years -= 1; months += 12; }
  const parts: string[] = [];
  if (years > 0) parts.push(`${years} yr${years > 1 ? 's' : ''}`);
  if (months > 0) parts.push(`${months} mo${months > 1 ? 's' : ''}`);
  return parts.length ? parts.join(' ') : '< 1 mo';
}

const entries = cvData.experience;
---

<section class="experience" id="experience" aria-label={t['experience.label']}>
  <div class="experience__inner">
    <SectionHeading label={t['experience.label']} number={t['experience.number']} />

    <div class="experience__timeline" data-timeline>
      {entries.map((entry, index) => (
        <ExperienceEntry
          entry={entry}
          index={index}
          duration={calcDuration(entry.startDate, entry.endDate)}
          t={t}
          lang={lang}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 6vw, 8rem);
    max-width: 72rem;
    margin: 0 auto;
  }

  .experience__timeline {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .experience__timeline::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0.5rem;
    bottom: 0;
    width: 1px;
    background-color: rgba(232, 255, 71, 0.15);
  }
</style>

<script>
  const entries = document.querySelectorAll<HTMLElement>('.experience__entry');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    entries.forEach(el => el.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (observed) => {
        observed.forEach((item) => {
          if (item.isIntersecting) {
            const el = item.target as HTMLElement;
            const index = Number(el.dataset.index ?? 0);
            el.style.transitionDelay = `${index * 100}ms`;
            el.classList.add('is-visible');
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );

    entries.forEach(el => observer.observe(el));
  }

  // Hover: dim non-hovered siblings
  entries.forEach((entry) => {
    entry.addEventListener('mouseenter', () => {
      entries.forEach((other) => {
        if (other !== entry) other.classList.add('is-dimmed');
      });
    });

    entry.addEventListener('mouseleave', () => {
      entries.forEach((other) => other.classList.remove('is-dimmed'));
    });
  });
</script>
