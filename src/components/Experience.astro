---
import type { Translations } from '../i18n/utils';
import SectionHeading from './SectionHeading.astro';
import cvData from '../data/cv.json';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const MONTHS: Record<string, number> = {
  January: 0, February: 1, March: 2, April: 3,
  May: 4, June: 5, July: 6, August: 7,
  September: 8, October: 9, November: 10, December: 11
};

function parseMonthYear(s: string): Date {
  const [month, year] = s.split(' ');
  return new Date(Number(year), MONTHS[month], 1);
}

function calcDuration(startStr: string, endStr: string | null): string {
  const start = parseMonthYear(startStr);
  const end = endStr ? parseMonthYear(endStr) : new Date();
  let years = end.getFullYear() - start.getFullYear();
  let months = end.getMonth() - start.getMonth();
  if (months < 0) { years -= 1; months += 12; }
  const parts: string[] = [];
  if (years > 0) parts.push(`${years} yr${years > 1 ? 's' : ''}`);
  if (months > 0) parts.push(`${months} mo${months > 1 ? 's' : ''}`);
  return parts.length ? parts.join(' ') : '< 1 mo';
}

const entries = cvData.experience;
---

<section class="experience" id="experience" aria-label={t['experience.label']}>
  <div class="experience__inner">
    <SectionHeading label={t['experience.label']} number={t['experience.number']} />

    <div class="experience__timeline" data-timeline>
      {entries.map((entry, index) => (
        <article
          class="experience__entry"
          data-index={index}
          aria-label={`${entry.title} at ${entry.company}`}
        >
          <div class={`experience__dot${entry.current ? ' experience__dot--current' : ''}`} aria-hidden="true"></div>

          <div class="experience__body">
            <h3 class="experience__title">{entry.title}</h3>
            <p class="experience__company">{entry.company}</p>

            <p class="experience__dates">
              {entry.startDate}
              <span aria-hidden="true"> — </span>
              {entry.current ? t['experience.present'] : entry.endDate}
              <span class="experience__duration">
                · {calcDuration(entry.startDate, entry.endDate)}
              </span>
            </p>

            <ul class="experience__bullets">
              {entry.bullets.map((bullet) => (
                <li class="experience__bullet">{bullet}</li>
              ))}
            </ul>

            <ul class="experience__stack" aria-label="Technologies">
              {entry.techStack.map((tech) => (
                <li class="experience__badge">{tech}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 6vw, 8rem);
    max-width: 72rem;
    margin: 0 auto;
  }

  .experience__timeline {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .experience__timeline::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0.5rem;
    bottom: 0;
    width: 1px;
    background-color: rgba(232, 255, 71, 0.15);
  }

  .experience__entry {
    position: relative;
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    padding-bottom: 3rem;
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .experience__entry.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .experience__entry.is-dimmed {
    opacity: 0.35;
    transition: opacity 0.25s ease;
  }

  .experience__dot {
    position: relative;
    top: 0.35rem;
    width: 0.875rem;
    height: 0.875rem;
    border-radius: 50%;
    border: 1px solid rgba(232, 255, 71, 0.4);
    background-color: transparent;
    justify-self: center;
    flex-shrink: 0;
  }

  .experience__dot--current {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 8px rgba(232, 255, 71, 0.6);
  }

  .experience__title {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .experience__company {
    font-size: clamp(0.85rem, 1.5vw, 0.95rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .experience__dates {
    font-size: clamp(0.7rem, 1.2vw, 0.8rem);
    font-family: 'Courier New', monospace;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.25rem;
    font-variant-numeric: tabular-nums;
  }

  .experience__duration {
    color: rgba(255, 255, 255, 0.3);
  }

  .experience__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .experience__bullet {
    font-size: clamp(0.8rem, 1.4vw, 0.875rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    padding-left: 1.25em;
    position: relative;
  }

  .experience__bullet::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(232, 255, 71, 0.4);
  }

  .experience__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .experience__badge {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 0.2em 0.55em;
  }

  @media (prefers-reduced-motion: reduce) {
    .experience__entry {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .experience__entry.is-dimmed {
      opacity: 0.35;
      transition: none;
    }
  }
</style>

<script>
  const entries = document.querySelectorAll<HTMLElement>('.experience__entry');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    entries.forEach(el => el.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (observed) => {
        observed.forEach((item) => {
          if (item.isIntersecting) {
            const el = item.target as HTMLElement;
            const index = Number(el.dataset.index ?? 0);
            el.style.transitionDelay = `${index * 100}ms`;
            el.classList.add('is-visible');
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );

    entries.forEach(el => observer.observe(el));
  }

  // Hover Level 2: dim non-hovered siblings
  entries.forEach((entry) => {
    entry.addEventListener('mouseenter', () => {
      entries.forEach((other) => {
        if (other !== entry) other.classList.add('is-dimmed');
      });
    });

    entry.addEventListener('mouseleave', () => {
      entries.forEach((other) => other.classList.remove('is-dimmed'));
    });
  });
</script>
