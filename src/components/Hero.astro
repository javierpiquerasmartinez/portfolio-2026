---
import type { Translations } from '../i18n/utils';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero__content">
    <h1 class="hero__name">
      <span class="letter from-top">J</span>
      <span class="letter from-bottom">P</span>
      <span class="letter from-top">D</span>
      <span class="letter from-bottom">E</span>
      <span class="letter from-top">V</span>
    </h1>
    <span class="sr-only">{t['hero.fullname']}</span>
    <p class="hero__title">{t['hero.subtitle']}</p>
    <div class="hero__cta-row">
      <span class="hero__available">{t['hero.available']}</span>
      <span class="hero__dot" aria-hidden="true">·</span>
      <a href="#contact" class="hero__cta" aria-label={t['hero.cta.aria']}>
        {t['hero.cta']}
      </a>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-indicator__dot"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: grid;
    place-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hero__name {
    display: flex;
    gap: 0.01em;
    font-size: clamp(4rem, 17vw, 18rem);
    font-weight: 800;
    line-height: 1;
    padding: 0 2vw;
  }

  .letter {
    display: inline-block;
    background: linear-gradient(180deg, #ffffff 30%, rgba(255, 255, 255, 0.35) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation-duration: 0.8s;
    animation-timing-function: var(--ease-smooth);
    animation-fill-mode: both;
  }

  .letter:nth-child(1) { animation-delay: 0s; }
  .letter:nth-child(2) { animation-delay: 0.08s; }
  .letter:nth-child(3) { animation-delay: 0.16s; }
  .letter:nth-child(4) { animation-delay: 0.24s; }
  .letter:nth-child(5) { animation-delay: 0.32s; }

  .from-top    { animation-name: slide-from-top; }
  .from-bottom { animation-name: slide-from-bottom; }

  .hero__title {
    font-size: clamp(0.85rem, 2vw, 1.25rem);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    opacity: 0;
    animation: fade-up 0.6s var(--ease-smooth) 0.55s forwards;
  }

  .hero__cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5em;
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    opacity: 0;
    animation: fade-up 0.6s var(--ease-smooth) 0.75s forwards;
  }

  .hero__available {
    color: var(--color-accent);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .hero__dot {
    color: rgba(255, 255, 255, 0.25);
  }

  .hero__cta {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
  }

  .hero__cta:hover,
  .hero__cta:focus-visible {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 1px;
    overflow: hidden;
    opacity: 0;
    animation: fade-in 0.4s ease 1.2s forwards;
  }

  .scroll-indicator__dot {
    width: 100%;
    height: 12px;
    background-color: rgba(255, 255, 255, 0.7);
    border-radius: 1px;
    animation: scroll-dot 1.4s ease-in-out 1.6s infinite alternate;
  }

  @media (prefers-reduced-motion: reduce) {
    .letter,
    .hero__title,
    .hero__cta-row,
    .scroll-indicator {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .scroll-indicator__dot {
      animation: none;
    }
  }
</style>
