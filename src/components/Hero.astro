---
---

<section class="hero">
  <div class="hero__content">
    <h1 class="hero__name">
      <span class="letter from-top">J</span>
      <span class="letter from-bottom">A</span>
      <span class="letter from-top">V</span>
      <span class="letter from-bottom">I</span>
    </h1>
    <p class="hero__title">Software Engineer</p>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-indicator__dot"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: grid;
    place-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hero__name {
    display: flex;
    gap: 0.01em;
    font-size: clamp(5rem, 22vw, 22rem);
    font-weight: 800;
    line-height: 1;
  }

  .letter {
    display: inline-block;
    background: linear-gradient(180deg, #ffffff 30%, rgba(255, 255, 255, 0.35) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    animation-fill-mode: both;
  }

  .letter:nth-child(1) { animation-delay: 0s; }
  .letter:nth-child(2) { animation-delay: 0.08s; }
  .letter:nth-child(3) { animation-delay: 0.16s; }
  .letter:nth-child(4) { animation-delay: 0.24s; }

  .from-top    { animation-name: slide-from-top; }
  .from-bottom { animation-name: slide-from-bottom; }

  .hero__title {
    font-size: clamp(0.85rem, 2vw, 1.25rem);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    opacity: 0;
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 1px;
    overflow: hidden;
    opacity: 0;
    animation: fade-in 0.4s ease 1.2s forwards;
  }

  .scroll-indicator__dot {
    width: 100%;
    height: 12px;
    background-color: rgba(255, 255, 255, 0.7);
    border-radius: 1px;
    animation: scroll-dot 1.4s ease-in-out 1.6s infinite alternate;
  }

  /* Keyframes */
  @keyframes slide-from-top {
    from { opacity: 0; transform: translateY(-3rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes slide-from-bottom {
    from { opacity: 0; transform: translateY(3rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(0.75rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes scroll-dot {
    from { transform: translateY(0); }
    to   { transform: translateY(28px); }
  }

  /* Accesibilidad */
  @media (prefers-reduced-motion: reduce) {
    .letter {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero__title {
      animation: none;
      opacity: 1;
    }

    .scroll-indicator {
      animation: none;
      opacity: 1;
    }

    .scroll-indicator__dot {
      animation: none;
    }
  }
</style>
