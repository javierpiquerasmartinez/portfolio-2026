---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id, data }) => {
    return id.startsWith('es/') && !data.draft;
  });
  return posts.map((post) => ({
    params: { slug: post.id.replace('es/', '').replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const t = useTranslations('es');

const formattedDate = post.data.date.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Rough read time: ~200 wpm
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Layout title={`${post.data.title} · ${t['site.title']}`} description={post.data.excerpt} lang="es">
  <main class="post">
    <div class="post__inner">
      <nav class="post__back">
        <a href="/es/blog">{t['blog.post.back']}</a>
      </nav>

      <article>
        <header class="post__header">
          <div class="post__meta">
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
            <span class="post__meta-sep">·</span>
            <span>{readTime} {t['blog.post.readTime']}</span>
            {post.data.tags.length > 0 && (
              <>
                <span class="post__meta-sep">·</span>
                <div class="post__tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="post__tag">{tag}</span>
                  ))}
                </div>
              </>
            )}
          </div>
          <h1 class="post__title">{post.data.title}</h1>
          <p class="post__excerpt">{post.data.excerpt}</p>
        </header>

        <div class="post__content">
          <Content />
        </div>
      </article>
    </div>
  </main>
</Layout>

<style>
  .post {
    padding-top: 7rem;
    padding-bottom: clamp(4rem, 10vw, 8rem);
    padding-left: clamp(1.25rem, 6vw, 8rem);
    padding-right: clamp(1.25rem, 6vw, 8rem);
  }

  .post__inner {
    max-width: 68ch;
    margin: 0 auto;
  }

  .post__back {
    margin-bottom: 2.5rem;
  }

  .post__back a {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .post__back a:hover {
    color: #ffffff;
  }

  .post__header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(1.5rem, 3vw, 2rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--text-faded);
    margin-bottom: 1.25rem;
  }

  .post__meta-sep {
    color: rgba(255, 255, 255, 0.2);
  }

  .post__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post__tag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    padding: 0.1em 0.45em;
  }

  .post__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .post__excerpt {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.65;
  }

  /* Prose content */
  .post__content {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.8);
  }

  .post__content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: #ffffff;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }

  .post__content :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    margin: 2rem 0 0.75rem;
  }

  .post__content :global(p) {
    margin: 0 0 1.25rem;
  }

  .post__content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post__content :global(strong) {
    color: #ffffff;
    font-weight: 600;
  }

  .post__content :global(ul),
  .post__content :global(ol) {
    margin: 0 0 1.25rem 1.5rem;
    padding: 0;
  }

  .post__content :global(li) {
    margin-bottom: 0.4rem;
  }

  .post__content :global(code):not(:global(pre code)) {
    font-family: 'Geist Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background-color: rgba(255, 255, 255, 0.07);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: rgba(255, 255, 255, 0.9);
  }

  .post__content :global(pre) {
    background-color: #111111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }

  .post__content :global(pre code) {
    font-family: 'Geist Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    background: none;
    padding: 0;
  }

  .post__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 0 0 1.75rem;
  }

  .post__content :global(thead) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .post__content :global(th) {
    text-align: left;
    font-weight: 600;
    color: #ffffff;
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .post__content :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.75);
    vertical-align: top;
  }

  .post__content :global(tr:last-child td) {
    border-bottom: none;
  }

  .post__content :global(tr:hover td) {
    background-color: rgba(255, 255, 255, 0.03);
  }

  .post__content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .post__back a {
      transition: none;
    }
  }
</style>
